---
// GalleryImage.astro - Individual image card component
// Image strategy: keep astro:assets <Image> for gallery cards to use build-time transforms and responsive variants.

import { Image } from 'astro:assets';

import type { MediaImage } from '../../lib/content-loader';

interface Props {
  image: MediaImage;
  eager?: boolean;
}

const { image, eager = false } = Astro.props;
const aspectRatio = `${image.width} / ${image.height}`;
---

<article data-testid="gallery-image" class="image-card">
  <div
    class="image-wrapper"
    style={`--aspect-ratio: ${aspectRatio}; --image-width: ${image.width}; --image-height: ${image.height};`}
    data-aspect-ratio={aspectRatio}
    data-image-width={String(image.width)}
    data-image-height={String(image.height)}
  >
    <Image
      src={image.src}
      alt={image.alt}
      width={image.width}
      height={image.height}
      widths={image.responsive.widths}
      sizes={image.responsive.sizes}
      format={image.responsive.format}
      quality={image.responsive.quality}
      loading={eager ? 'eager' : 'lazy'}
      decoding={eager ? 'auto' : 'async'}
    />
  </div>
  {image.caption && <p class="caption">{image.caption}</p>}
</article>

<style>
  .image-card {
    /* Minimal chrome - just subtle background, no heavy border */
    background: rgba(255, 255, 255, 0.65);
    border-radius: 0.375rem;
    overflow: hidden;
    /* Very subtle border that doesn't fight starry atmosphere */
    border: 1px solid rgba(203, 213, 225, 0.2);
    transition:
      box-shadow var(--motion-duration-md, 250ms) var(--motion-ease-smooth, ease),
      transform var(--motion-duration-md, 250ms) var(--motion-ease-smooth, ease);
  }

  .image-card:hover {
    box-shadow: 0 2px 8px rgba(16, 42, 67, 0.08);
    transform: translateY(-1px);
  }

  .image-wrapper {
    aspect-ratio: var(--aspect-ratio);
    overflow: hidden;
    position: relative;
    background: rgba(241, 245, 249, 0.5);
  }

  .image-wrapper :global(img) {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .caption {
    margin: 0;
    padding: 0.625rem 0.875rem;
    /* Subdued caption - lighter text on transparent surface */
    color: var(--text-muted);
    font-size: 0.8125rem;
    /* No border-top to keep it light; just subtle background separation */
    background: rgba(248, 250, 252, 0.4);
    line-height: 1.4;
  }

</style>
